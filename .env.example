# ===========================================
# Claude Slack Bot Configuration
# Copy this file to .env and fill in your values
# ===========================================

# --- Required: Slack Tokens ---
# Bot User OAuth Token (starts with xoxb-)
# Get from: Slack App > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token (starts with xapp-)
# Get from: Slack App > Basic Information > App-Level Tokens
# Create with scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-token

# --- Optional: Bot Behavior ---
# Always mention this Slack user ID in responses (e.g., "U05JK5UUR7U")
# ALWAYS_MENTION_USER=

# Channel ID for detailed review discussions (검토: prefix sends here)
# SLACK_REVIEW_CHANNEL_ID=C0123456789

# Additional directory for Claude to explore (default: parent of project)
# CLAUDE_ADD_DIR=/path/to/your/codebase

# Claude CLI timeout in seconds (default: 1800 = 30 min)
# CLAUDE_TIMEOUT=1800

# --- Optional: Thread Summarization ---
# Summarize threads with more than N messages (default: 5)
# SUMMARY_THRESHOLD=5

# Cache TTL in seconds (default: 3600 = 1 hour)
# CACHE_TTL_SECONDS=3600

# --- Optional: ClickHouse Integration ---
# Set to "true" to enable ClickHouse query features
# CLICKHOUSE_ENABLED=false
# CLICKHOUSE_HOST=your-clickhouse-host.com
# CLICKHOUSE_PORT=443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_SECURE=true
# CLICKHOUSE_DEFAULT_SERVICE=your-service-name
